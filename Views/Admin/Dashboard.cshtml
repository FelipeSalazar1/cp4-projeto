@model List<Solicitacao>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Painel do Tech Líder</h2>
            <p class="text-muted mb-0">Aprove ou reprove as solicitações recebidas.</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Ainda não existem solicitações cadastradas.</div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0 bg-white">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Problema</th>
                        <th>Status</th>
                        <th>Data</th>
                        <th>Dev</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>
                                <strong>@item.NomeCliente</strong><br />
                                <small class="text-muted">@item.EmailCliente</small>
                            </td>
                            <td>@item.ProblemaNome</td>
                            <td>
                                @if (item.Status == "Aprovada")
                                {
                                    <span class="badge bg-success">@item.Status</span>
                                }
                                else if (item.Status == "Reprovada")
                                {
                                    <span class="badge bg-danger">@item.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@item.Status</span>
                                }
                            </td>
                            <td>@item.DataSolicitacao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.DevResponsavel))
                                {
                                    <span>@item.DevResponsavel</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex flex-wrap gap-2 justify-content-center">
                                    <a asp-action="Aprovar" asp-route-id="@item.Id" class="btn btn-sm btn-success">Aprovar</a>
                                    <a asp-action="Reprovar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Reprovar</a>

                                    @if (!string.IsNullOrWhiteSpace(item.WhatsAppDev))
                                    {
                                        var mensagem = $"Olá, {item.DevResponsavel}! Nova solicitação aprovada: {item.ProblemaNome}. Cliente: {item.NomeCliente} - {item.EmailCliente}";
                                        var linkWhats = $"https://wa.me/{item.WhatsAppDev}?text={Uri.EscapeDataString(mensagem)}";
                                        <a href="@linkWhats" target="_blank" class="btn btn-sm btn-dark">Enviar WhatsApp</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
