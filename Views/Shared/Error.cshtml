@model ErrorViewModel
@{
    ViewData["Title"] = "Erro";
}

<div class="container py-5">
    <div class="alert alert-danger">
        <h2>Ocorreu um erro.</h2>
        @if (Model.ShowRequestId)
        {
            <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
        }
    </div>
</div>
